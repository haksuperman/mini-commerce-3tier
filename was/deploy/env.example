# ============================================================
# Mini Commerce — WAS Tier environment (production)
# Install to /etc/mini-commerce/was.env (EnvironmentFile in systemd unit).
# Fill in <...> placeholders. Never commit the real file.
# ============================================================

APP_ENV=production
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=<production-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (db tier — MySQL 8 on a separate host / RDS) ---
DATABASE_URL=mysql+asyncmy://minicommerce:<password>@<DB_HOST>:3306/minicommerce

# --- Redis (cache tier — separate host / ElastiCache) ---
REDIS_URL=redis://<CACHE_HOST>:6379/0

# --- CORS ---
# With the web-tier nginx reverse proxy the browser only hits the web tier, so
# CORS is effectively unused; set defensively to the public web domain.
ALLOWED_ORIGINS=http://<web-tier-domain>

# --- Payment Mock ---
MOCK_PAYMENT_FAILURE_RATE=0.0

# --- Migrations / Seed ---
# Run migrations once from deploy.sh, not on every worker start.
RUN_MIGRATIONS_ON_START=false
SEED_ON_START=false

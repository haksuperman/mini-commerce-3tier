# Web Tier deploy environment — copy to deploy/.env and edit.

# Private address of the WAS (FastAPI/Gunicorn) tier that nginx proxies
# /api/ requests to. Use the WAS host's private IP and port 8000.
WAS_UPSTREAM=10.0.2.10:8000

# Vite API base URL baked into the SPA bundle at build time.
# Keep this EMPTY so the SPA calls relative /api/v1 paths, which this
# tier's nginx reverse-proxies to WAS_UPSTREAM (no CORS needed).
VITE_API_BASE_URL=

# Optional overrides (defaults shown):
# WEB_ROOT=/var/www/mini-commerce
# NGINX_CONF_DEST=/etc/nginx/conf.d/mini-commerce-web.conf

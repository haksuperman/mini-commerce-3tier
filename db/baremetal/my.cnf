# ============================================================
# Mini Commerce — Data Tier MySQL 8 server config (bare metal)
# Install to /etc/mysql/conf.d/mini-commerce.cnf (Ubuntu) or
# /etc/my.cnf.d/mini-commerce.cnf (Amazon Linux / RHEL).
# Mirrors the original docker-compose `command:` options.
# ============================================================
[mysqld]
# Charset / collation — matches the app's utf8mb4 expectation.
character-set-server          = utf8mb4
collation-server              = utf8mb4_unicode_ci

# asyncmy / mysql_native_password compatibility.
default-authentication-plugin = mysql_native_password

# Listen on all interfaces so the WAS tier (separate host) can connect.
# Lock this down with a security group / firewall: 3306 from the WAS SG only.
bind-address                  = 0.0.0.0
port                          = 3306

# Reasonable defaults for a small demo instance.
max_connections               = 200
innodb_buffer_pool_size       = 512M

[client]
default-character-set         = utf8mb4
